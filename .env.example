# MindMapVault Server - environment template
# Copy to backend/.env for local source-based development.
# Copy to .env or another file only when you want to pass it to docker with --env-file.
# The backend loads .env automatically when the file is present in its working directory.
# NEVER commit real credentials.

# Network
HOST=0.0.0.0
PORT=8090

# Database selection
# Use SQL_DSN as the canonical DSN. POSTGRES_DSN is accepted for backward compatibility.
DB_ENGINE=sql
SQL_DSN=postgres://postgres:postgres@127.0.0.1:5432/mindmapvault
POSTGRES_DSN=

# Object storage
S3_ENDPOINT=http://127.0.0.1:9000
S3_PUBLIC_ENDPOINT=http://127.0.0.1:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=mindmapvault
S3_REGION=us-east-1
S3_PRESIGN_EXPIRY_SECS=3600

# Auth
JWT_SECRET=replace_with_long_random_secret
JWT_ACCESS_EXPIRY_SECS=900
JWT_REFRESH_EXPIRY_SECS=2592000

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5274,http://127.0.0.1:8090,http://tauri.localhost

# Optional diagnostics
ENABLE_DIAGNOSTICS_ROUTES=false

# Optional admin API protection
ADMIN_API_TOKEN=replace_with_admin_api_token